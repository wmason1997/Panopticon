# Local dev: direct to API (bypasses Next.js proxy, avoids cross-origin cookie issues locally)
# Production: set to /api so all requests go through the Next.js proxy (same-origin cookie)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Used server-side by the Next.js proxy route (web/app/api/[...path]/route.ts)
# Not needed for local dev if NEXT_PUBLIC_API_URL points directly to the API
API_URL=http://localhost:3001
