  "query": "\n        UPDATE notes SET\n            content    = COALESCE($1, content),\n            is_public  = COALESCE($2, is_public),\n            updated_at = NOW()\n        WHERE id = $3 AND user_id = $4\n        RETURNING id, weekly_progress_id, user_id, content, is_public, created_at, updated_at\n        ",
