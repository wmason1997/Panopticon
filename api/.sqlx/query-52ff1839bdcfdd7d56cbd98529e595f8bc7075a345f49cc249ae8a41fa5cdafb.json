{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT n.id, n.weekly_progress_id, n.user_id, n.content, n.is_public, n.created_at, n.updated_at\n        FROM notes n\n        JOIN weekly_progress wp ON wp.id = n.weekly_progress_id\n        WHERE n.weekly_progress_id = $1\n          AND wp.user_id = $2\n        ORDER BY n.created_at ASC\n        ",
