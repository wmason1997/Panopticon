  "query": "\n        UPDATE weekly_progress SET\n            completed_count = COALESCE($1, completed_count),\n            updated_at      = NOW()\n        WHERE id = $2 AND user_id = $3\n        RETURNING id, goal_id, user_id, week_start_date,\n                  completed_count, target_count, is_published,\n                  created_at, updated_at\n        ",
