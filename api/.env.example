DATABASE_URL=postgres://panopticon:panopticon@localhost:5432/panopticon

# Google OAuth2 — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Cookie signing secret — generate with: openssl rand -base64 64
SESSION_SECRET=changeme-generate-a-real-secret-before-deploying

# Server
HOST=0.0.0.0
PORT=3001

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# Rust log level
RUST_LOG=panopticon_api=debug,tower_http=debug
